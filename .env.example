APP_ENV=dev
TZ=Asia/Tokyo

V12_API_PUBLIC_PORT=8000
QUANTOPS_PUBLIC_PORT=8010

V12_TIMEOUT_SECONDS=10
V12_MOCK_MODE=false

AHB_MODE=paper
AHB_USE_LIVE_MARKET_DATA=true
AHB_RUNTIME_DIR=/app/runtime
AHB_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,WLDUSDT,DOGEUSDT
AHB_TIMEFRAME=15m
WORKER_INTERVAL_SEC=60
PAPER_CYCLE_INTERVAL_SEC=60

AHB_PRICE_SOURCE=binance_book_ticker
AHB_ALLOW_SYNTHETIC_QUOTE_FALLBACK=true
AHB_STRICT_LIVE_QUOTES=false
AHB_BINANCE_REST_BASE_URL=https://api.binance.com
AHB_QUOTE_TIMEOUT_SEC=5

QUANTOPS_DB_PATH=/app/data/quantops.duckdb